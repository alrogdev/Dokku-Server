type: http
name: telegram
log_level: info
format: |
  {
    "chat_id": "{{ telegram_chat_id }}",
    "text": "🚨 <b>CrowdSec Alert</b> - {{ server_hostname }}\n\n{% raw %}{{range . -}}{{range .Decisions -}}{% endraw %}🔴 {% raw %}{{.Value}}{% endraw %} banned for {% raw %}{{.Duration}}{% endraw %}\n📋 Scenario: {% raw %}{{.Scenario}}{% endraw %}\n{% raw %}{{end -}}{{end -}}{% endraw %}\n⏰ {% raw %}{{range . -}}{{.CreatedAt}}{{end -}}{% endraw %}",
    "parse_mode": "HTML"
  }
url: https://api.telegram.org/bot{{ telegram_bot_token }}/sendMessage
method: POST
headers:
  Content-Type: "application/json"
