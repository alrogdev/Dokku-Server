#!/bin/bash
# /usr/local/bin/crowdsec-telegram-notify.sh
# Telegram notification script for CrowdSec alerts

TOKEN="{{ telegram_bot_token }}"
CHAT_ID="{{ telegram_chat_id }}"
MESSAGE="$1"

if [ -z "$MESSAGE" ]; then
    echo "Usage: $0 <message>"
    exit 1
fi

curl -s -X POST "https://api.telegram.org/bot${TOKEN}/sendMessage" \
    -d "chat_id=${CHAT_ID}" \
    -d "text=${MESSAGE}" \
    -d "parse_mode=HTML" > /dev/null 2>&1
