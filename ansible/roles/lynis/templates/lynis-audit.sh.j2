#!/bin/bash
# /usr/local/bin/lynis-audit.sh
# Lynis security audit with Telegram notifications

TOKEN="{{ telegram_bot_token }}"
CHAT_ID="{{ telegram_chat_id }}"
HOSTNAME=$(hostname)
DATE=$(date '+%Y-%m-%d %H:%M:%S')
REPORT_FILE="/var/log/lynis/lynis-report-${DATE}.log"

# Run Lynis audit
lynis audit system --quiet --report-file "$REPORT_FILE"

# Extract key findings
HARDENING_INDEX=$(grep "Hardening index" "$REPORT_FILE" | awk '{print $4}' | tr -d '[]')
WARNINGS=$(grep -c "Warning:" "$REPORT_FILE" || echo "0")
SUGGESTIONS=$(grep -c "Suggestion:" "$REPORT_FILE" || echo "0")

# Send Telegram notification
MESSAGE="🔒 <b>Lynis Security Audit</b> - ${HOSTNAME}
📅 ${DATE}
📊 <b>Hardening Index:</b> ${HARDENING_INDEX}/100
⚠️ <b>Warnings:</b> ${WARNINGS}
💡 <b>Suggestions:</b> ${SUGGESTIONS}

📄 Full report: ${REPORT_FILE}"

curl -s -X POST "https://api.telegram.org/bot${TOKEN}/sendMessage" \
    -d "chat_id=${CHAT_ID}" \
    -d "text=${MESSAGE}" \
    -d "parse_mode=HTML" > /dev/null 2>&1

echo "[$DATE] Lynis audit completed. Hardening Index: ${HARDENING_INDEX}"
